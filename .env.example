# CTEM Leader Lab — Environment Configuration
# Copy this file to .env and adjust values as needed.

# ---- Backend ----

# Path to the SQLite database file.
# In Docker, this should point to the mounted volume path.
# Default: backend/ctem.db
# CTEM_DB_PATH=backend/ctem.db

# Comma-separated list of allowed CORS origins.
# In Docker Compose the frontend Nginx proxies /api to the backend,
# so the backend only needs to trust the Nginx origin.
# Default: http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175
# CORS_ORIGINS=http://localhost:8080

# ---- Frontend (build-time) ----

# Set to "true" to enable live backend mode with same-origin API calls.
# When true, CSV import/export and session features are available.
# When false/omitted, the app uses static JSON data (GitHub Pages mode).
# VITE_API_LIVE=false

# Base URL of the backend API for development mode.
# When set, the frontend sends API requests directly to this URL.
# When empty, API requests go to the same origin (Nginx proxy in Docker).
# VITE_API_BASE_URL=http://localhost:8000
